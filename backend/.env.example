# ─── PROMETHEUS BACKEND ──────────────────────
PORT=3001
NETWORK_NAME=shelbynet
EXPLORER_NETWORK=shelbynet
SHELBY_NETWORK=shelbynet

# Server wallet (sponsors reads + pays gas for record_read)
SERVER_PRIVATE_KEY=ed25519-priv-0xYOUR_KEY_HERE

# Deployed contract address (from deploy.sh output)
PROMETHEUS_CONTRACT=0xYOUR_CONTRACT_ADDRESS_HERE

# Shelby shelbynet
SHELBY_HOST=api.shelbynet.shelby.xyz
SHELBY_API_KEY=
SHELBY_API_KEY_HEADER=x-api-key
SHELBY_RPC_BASE_URL=
SHELBY_RPC_API_KEY=
SHELBY_INDEXER_BASE_URL=
SHELBY_INDEXER_API_KEY=
SHELBY_EXPIRATION_DAYS=30
SHELBY_ACCOUNT=0xYOUR_SHELBY_ACCOUNT_HERE

# Aptos shelbynet
APTOS_NODE_URL=https://api.shelbynet.shelby.xyz/v1
APTOS_API_KEY=
