# ─── PROMETHEUS BACKEND (APTOS TESTNET) ──────
PORT=3001
NETWORK_NAME=testnet
EXPLORER_NETWORK=testnet
SHELBY_NETWORK=testnet

# Server wallet (sponsors reads + pays gas for record_read)
SERVER_PRIVATE_KEY=ed25519-priv-0xYOUR_KEY_HERE

# Deployed contract address (from deploy_testnet.sh output)
PROMETHEUS_CONTRACT=0xYOUR_CONTRACT_ADDRESS_HERE

# Shelby testnet
SHELBY_HOST=api.testnet.shelby.xyz
SHELBY_API_KEY=
SHELBY_API_KEY_HEADER=x-api-key
SHELBY_RPC_BASE_URL=https://api.testnet.shelby.xyz/shelby
SHELBY_RPC_API_KEY=
SHELBY_INDEXER_BASE_URL=
SHELBY_INDEXER_API_KEY=
SHELBY_EXPIRATION_DAYS=30
SHELBY_ACCOUNT=0xYOUR_SHELBY_ACCOUNT_HERE

# Aptos testnet
APTOS_NODE_URL=https://api.testnet.aptoslabs.com/v1
APTOS_API_KEY=
